---
---

<section id="features" class="bg-[#F0EDE8] pt-32 pb-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <div>
        <p class="text-kredio-gray-text text-xs font-semibold uppercase tracking-widest mb-4">Features</p>
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-black leading-tight mb-6">
          Best features<br/>provided by kredio
        </h2>
        <p class="text-kredio-gray-text text-sm leading-relaxed max-w-sm mb-10">
          Kredio is more of a mindset than technology or industry. Our product is designed by
          industry veterans to solve these problems. It will save you time, money, and heartache.
        </p>
        <div class="flex items-center gap-6">
          <a href="#"
             class="bg-black text-white text-sm font-semibold px-7 py-3.5 rounded-full
                    hover:bg-neutral-800 transition-colors">
            Get Started
          </a>
          <a href="#" class="text-black text-sm font-medium flex items-center gap-1.5 hover:gap-3 transition-all">
            Learn More
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">

        <div class="bg-white rounded-2xl p-6 shadow-sm flex flex-col items-center text-center gap-3">
          <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6E6E73" stroke-width="1.5">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <p class="text-black font-semibold text-sm">Protection</p>
          <p class="text-kredio-gray-text text-xs leading-relaxed">Data protection guarantees</p>
        </div>

        <div class="bg-kredio-dark rounded-2xl p-6 shadow-xl flex flex-col gap-3">
          <p class="text-white font-semibold text-sm">Tracking</p>
          <svg viewBox="0 0 120 50" class="w-full" fill="none">
            <defs>
              <linearGradient id="wave-grad" x1="0" y1="0" x2="120" y2="0" gradientUnits="userSpaceOnUse">
                <stop offset="0%"   stop-color="#FF6B9D"/>
                <stop offset="100%" stop-color="#9B59B6"/>
              </linearGradient>
            </defs>
            <path d="M0 35 C15 10, 25 45, 40 25 C55 5, 65 40, 80 20 C95 0, 110 35, 120 15"
                  stroke="url(#wave-grad)" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          <p class="text-white/50 text-xs">Track all your financial transactions</p>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-sm flex flex-col items-center text-center gap-3">
          <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6E6E73" stroke-width="1.5">
              <polygon points="12,2 13.5,10.5 22,12 13.5,13.5 12,22 10.5,13.5 2,12 10.5,10.5"/>
            </svg>
          </div>
          <p class="text-black font-semibold text-sm">Flexibility</p>
          <p class="text-kredio-gray-text text-xs leading-relaxed">Delivery through multiple channels</p>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-sm flex flex-col items-center text-center gap-3">
          <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6E6E73" stroke-width="1.5">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </div>
          <p class="text-black font-semibold text-sm">Easiness</p>
          <p class="text-kredio-gray-text text-xs leading-relaxed">Feel free to transact anywhere, anytime</p>
        </div>

      </div>
    </div>
  </div>
</section>
