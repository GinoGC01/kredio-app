<section class="stats" id="stats">
  <div class="container">
    <div class="stats__grid">
      <div class="stats__item" data-reveal="scale">
        <span class="stats__number" data-counter data-target="98" data-suffix="%"></span>
        <span class="stats__label">de recupero</span>
      </div>
      <div class="stats__item" data-reveal="scale" data-delay="100">
        <span class="stats__number" data-counter data-target="1500000" data-prefix="+"></span>
        <span class="stats__label">créditos gestionados</span>
      </div>
      <div class="stats__item" data-reveal="scale" data-delay="200">
        <span class="stats__number" data-counter data-target="65000" data-prefix="+"></span>
        <span class="stats__label">empresas activas</span>
      </div>
      <div class="stats__item" data-reveal="scale" data-delay="300">
        <span class="stats__number" data-counter data-target="300000" data-prefix="+"></span>
        <span class="stats__label">transacciones</span>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .stats {
    border-block: 1px solid var(--c-border);
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .stats__item {
    text-align: center;
  }

  .stats__number {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: var(--text-stat);
    font-weight: 700;
    color: var(--c-text-primary);
    font-variant-numeric: tabular-nums;
    margin-bottom: 4px;
  }

  .stats__label {
    display: block;
    font-size: 13px;
    color: var(--c-text-muted);
    letter-spacing: 0.04em;
  }

  @media (max-width: 767px) {
    .stats__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px 16px;
    }
  }
</style>
