<div class="relative flex justify-center items-center h-64">

  <div class="absolute w-52 aspect-[1.586/1] rounded-2xl p-4
              -rotate-[14deg] -translate-x-40 translate-y-6 z-10
              shadow-[0_20px_60px_rgba(0,0,0,0.5)]
              bg-gradient-to-tr from-[#00F2FE] to-[#4FACFE]">
    <div class="flex flex-col justify-between h-full">
      <span class="text-white font-bold text-sm tracking-tight">kredio</span>
      <div class="flex items-center gap-1">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
          <path d="M5 12.55a11 11 0 0 1 14.08 0"/>
          <path d="M1.42 9a16 16 0 0 1 21.16 0"/>
          <path d="M8.53 16.11a6 6 0 0 1 6.95 0"/>
          <circle cx="12" cy="20" r="1" fill="white"/>
        </svg>
      </div>
    </div>
  </div>

  <div class="absolute w-52 aspect-[1.586/1] rounded-2xl p-4
              rotate-[14deg] translate-x-40 translate-y-6 z-10
              shadow-[0_20px_60px_rgba(0,0,0,0.3)]
              bg-gradient-to-tr from-[#FFE8B6] to-[#FF9A9E]">
    <div class="flex flex-col justify-between h-full">
      <span class="text-black/80 font-bold text-sm tracking-tight">kredio</span>
      <div class="w-8 h-6 rounded bg-yellow-400/80 self-end"></div>
    </div>
  </div>

  <div class="relative w-56 aspect-[1.586/1] rounded-2xl p-4 z-20
              shadow-[0_30px_80px_rgba(0,0,0,0.6)]
              bg-gradient-to-br from-[#FF0844] via-[#FF6B9D] to-[#FFB199]">
    <div class="flex flex-col justify-between h-full">
      <span class="text-white font-bold text-sm tracking-tight">kredio</span>
      <div class="flex items-center justify-between">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
          <path d="M5 12.55a11 11 0 0 1 14.08 0"/>
          <path d="M8.53 16.11a6 6 0 0 1 6.95 0"/>
          <circle cx="12" cy="20" r="1" fill="white"/>
        </svg>
        <div class="w-7 h-5 rounded bg-white/30"></div>
      </div>
    </div>
  </div>
</div>

<div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 z-30">
  <button class="w-20 h-20 rounded-full bg-[#111] border-4 border-[#F0EDE8]
                 flex flex-col items-center justify-center gap-1
                 shadow-xl hover:scale-105 transition-transform">
    <span class="text-white text-[6px] font-bold tracking-[0.12em] uppercase text-center leading-tight">
      EXPLORE<br/>MORE
    </span>
    <svg width="12" height="8" viewBox="0 0 12 8" fill="none">
      <defs>
        <linearGradient id="tri" x1="0" y1="0" x2="12" y2="0">
          <stop offset="0%" stop-color="#00F2FE"/>
          <stop offset="100%" stop-color="#4FACFE"/>
        </linearGradient>
      </defs>
      <polygon points="6,8 0,0 12,0" fill="url(#tri)"/>
    </svg>
  </button>
</div>
